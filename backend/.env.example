# ToonForge backend configuration. Copy to .env and edit.

# --- Core ---
TOONFORGE_DATA_DIR=./data           # assets + sqlite db live here
TOONFORGE_DB_PATH=./data/toonforge.sqlite3
TOONFORGE_HOST=127.0.0.1
TOONFORGE_PORT=8000

# --- Languages (EN + FR per spec) ---
TOONFORGE_LANGUAGES=en,fr
TOONFORGE_DEFAULT_LANGUAGE=en

# --- Provider selection (capability -> provider name) ---
# Defaults are chosen to run free on a CPU-only machine.
PROVIDER_IMAGE=sdcpp                  # sdcpp (local SD-Turbo, offline CPU, default) | pollinations (free cloud) | higgsfield (needs key) | mock (test) | flux_local (needs GPU)
PROVIDER_TTS=piper                   # piper (local CPU) | xtts_local (needs GPU)
PROVIDER_ALIGN=faster_whisper        # faster_whisper (local CPU)
PROVIDER_MUSIC=symbolic              # symbolic (local CPU melody) | musicgen_local (needs GPU)
PROVIDER_ASSEMBLY=ffmpeg             # ffmpeg (local)
PROVIDER_CONSISTENCY=phash           # phash (local CPU) | clip_local (needs GPU)
PROVIDER_LLM=openrouter              # openrouter (free :free models, key-gated) | mock (test)
PROVIDER_VIDEO=                      # empty = disabled until a GPU/cloud provider is configured
PROVIDER_SVS=tts_pitch                        # empty = disabled (DiffSinger needs GPU)
PROVIDER_LIPSYNC=                    # empty = disabled (needs GPU)

# --- Optional cloud provider keys (leave blank to keep everything free/local) ---
# Pollinations works keyless but its anonymous tier is rate-limited (~1 concurrent/IP).
# A FREE token from https://enter.pollinations.ai removes the limit — recommended.
POLLINATIONS_TOKEN=
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_BASE=https://api.higgsfield.ai
# Cloudflare Workers AI — FREE modern Flux images (no GPU, no card, ~10k neurons/day).
# Get: dash.cloudflare.com -> Workers AI -> API token. Then set PROVIDER_IMAGE=cloudflare.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell


# OpenRouter — the ONLY cloud capability, for songwriting (prompt -> lyrics/chorus/scenes).
# Free: a `:free` model costs $0 (rate-limited ~20/min, 50/day). Get a key: https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# --- Kaggle GPU render (the app dispatches the real sung+animated render to a FREE Kaggle GPU
# and pulls back the MP4 — see docs/APP_GPU_RENDER.md). The GPU work can't run on a no-GPU box.
# Setup ONCE: kaggle.com -> Settings -> API -> "Create New Token" -> save kaggle.json to
# ~/.kaggle/kaggle.json (or set KAGGLE_USERNAME/KAGGLE_KEY below). Phone-verify the account for GPU.
KAGGLE_USERNAME=
KAGGLE_KEY=
KAGGLE_RENDER_REPO=https://github.com/4-7-9-0-6/Video_Generator.git   # public repo the kernel clones
KAGGLE_KERNEL_SLUG=                  # blank -> <username>/toonforge-render
KAGGLE_POLL_INTERVAL_S=30
KAGGLE_TIMEOUT_S=3600

# --- Piper (local TTS) ---
# Voice model files (.onnx). Download via scripts/setup_check.py guidance.
PIPER_VOICE_EN=en_US-amy-medium
PIPER_VOICE_FR=fr_FR-siwis-medium
PIPER_MODELS_DIR=./models/piper

# --- faster-whisper ---
WHISPER_MODEL=base                   # tiny|base|small (CPU-friendly). int8 compute.

# --- sdcpp (local SD-Turbo image gen via stable-diffusion.cpp) ---
# Install once: python scripts/install_sdcpp.py && python scripts/download_sd_model.py
SDCPP_STEPS=4                        # SD-Turbo sample steps (1=fastest, 4=more coherent)
SDCPP_CFG=1.0                        # SD-Turbo wants cfg-scale 1.0
SDCPP_MAX_SIDE=640                   # cap generation resolution (longest side) then upscale — bounds CPU time
# SDCPP_THREADS=                     # default = CPU core count
# SDCPP_BIN=                         # override path to sd-cli(.exe)
# SD_MODEL=                          # override path to a *.gguf model

# --- Quality gates (from spec section 6) ---
CONSISTENCY_MIN_SCORE=0.85           # auto-regenerate below this
LIPSYNC_MAX_OFFSET_MS=80
